# Supabase — get from your project dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-side only — NEVER expose to browser
SUPABASE_SERVICE_ROLE_KEY=

# ── Payment gateway webhook (set when the bank/gateway is connected) ─────────
# For Xendit: use your Webhook Verification Token (Dashboard → Settings →
# Developers → Webhooks). Xendit sends it in the x-callback-token header.
# A generic HMAC-SHA256 x-signature mode is also supported for other gateways.
# The payment webhook stays inert (returns 503) until this is set.
# Must MATCH the app_config 'payment_webhook_secret' row in Supabase:
#   insert into app_config (key, value) values ('payment_webhook_secret', '<same value>');
PAYMENT_WEBHOOK_SECRET=

# ── WhatsApp via WAHA (optional — falls back to log-only "simulated send") ───
# WAHA (https://waha.devlike.pro) runs a real WhatsApp session (scanned by
# QR code, like WhatsApp Web) and exposes it as an HTTP API — no Meta
# Business verification needed, no 24h session window, no message templates.
#   WAHA_BASE_URL: e.g. https://waha.soedarsono.com
#   WAHA_API_KEY: the instance's API key, if it requires one
#   WAHA_SESSION: the session name to send from (default "default")
WAHA_BASE_URL=
WAHA_API_KEY=
WAHA_SESSION=default

# One or more admin WhatsApp numbers (E.164, comma-separated) that get an
# alert the moment a client books, e.g. "+6281234567890,+6289876543210".
WHATSAPP_ADMIN_NUMBERS=

# Bank transfer details sent automatically to the client right after they
# book, so they know where to pay.
BCA_BANK_NAME=BCA
BCA_ACCOUNT_NUMBER=
BCA_ACCOUNT_NAME=

# ── Stripe ──────────────────────────────────────────────────────────────────
# Get from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_

# Webhook secret — from Stripe dashboard → Webhooks → your endpoint
# For local dev: stripe listen --forward-to localhost:3000/api/stripe/webhooks
STRIPE_WEBHOOK_SECRET=whsec_

# Your price IDs from Stripe dashboard → Products
NEXT_PUBLIC_STRIPE_PRICE_MONTHLY=price_
NEXT_PUBLIC_STRIPE_PRICE_YEARLY=price_

# ── Stripe Connect (set by Vibe Launchpad when provisioned via platform) ────
# Leave blank if running standalone with your own Stripe account
STRIPE_CONNECT_ACCOUNT_ID=
STRIPE_PLATFORM_FEE_PERCENT=

# ── App URL (used for redirect URLs) ────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
